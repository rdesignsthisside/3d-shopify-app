{
  "name": "3d-shopify-app",
  "version": "1.0.0",
  "description": "Shopify app for managing 3D GLB and image templates with Liquid integration",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --exec node --experimental-modules server/index.js",
    "client:dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "test": "vitest"
  },
  "dependencies": {
    "@shopify/shopify-app-express": "^2.7.0",
    "@shopify/shopify-api": "^9.2.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1"
  }
}
